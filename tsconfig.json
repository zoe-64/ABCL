{
  "compilerOptions": {
    "target": "ESNext",                              
    "module": "ESNext",               
    "moduleResolution": "Bundler",
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    
    "baseUrl": "src",
    "paths": {
        "@/*": ["*"]
    }
  },
  "include": [
    "node_modules/bc-stubs/bc/**/*.d.ts",
    "./src/**/*",
    "./data/*.css",
    "./data/*.html",
    "./data/*.json"

  ],

} 
